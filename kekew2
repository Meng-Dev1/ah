-- ========================
-- Animasi
-- ========================
local ease = TweenInfo.new(0.6, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
local easeSlow = TweenInfo.new(1, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)

local function tween(obj, props, ti)
    TweenService:Create(obj, ti or ease, props):Play()
end

task.spawn(function()
    -- Fade in BG
    tween(BG, {BackgroundTransparency = 0.4}, TweenInfo.new(0.8, Enum.EasingStyle.Quint))
    task.wait(0.3)

    -- Slide container dari bawah + fade in
    tween(Container, {
        BackgroundTransparency = 0,
        Position = UDim2.fromScale(0.5, 0.5)
    }, easeSlow)
    tween(UIStroke, {Transparency = 0}, easeSlow)
    task.wait(0.4)

    -- Icon
    tween(Icon, {ImageTransparency = 0}, ease)
    task.wait(0.3)

    -- Title
    tween(Title, {TextTransparency = 0}, ease)
    task.wait(0.2)

    -- Divider expand
    tween(Divider, {Size = UDim2.new(0.7, 0, 0, 1)}, ease)
    task.wait(0.3)

    -- Message
    tween(Message, {TextTransparency = 0}, TweenInfo.new(0.8, Enum.EasingStyle.Quint))
    task.wait(0.3)

    -- Version
    tween(Version, {TextTransparency = 0}, ease)
    task.wait(4)

    -- Fade out semua
    tween(BG, {BackgroundTransparency = 1}, TweenInfo.new(1.2, Enum.EasingStyle.Quint))
    tween(Container, {BackgroundTransparency = 1, Position = UDim2.fromScale(0.5, 0.6)}, TweenInfo.new(1, Enum.EasingStyle.Quint, Enum.EasingDirection.In))
    tween(UIStroke, {Transparency = 1}, ease)
    tween(Icon, {ImageTransparency = 1}, ease)
    tween(Title, {TextTransparency = 1}, ease)
    tween(Divider, {Size = UDim2.new(0, 0, 0, 1)}, ease)
    tween(Message, {TextTransparency = 1}, ease)
    tween(Version, {TextTransparency = 1}, ease)
    task.wait(1.2)

    ScreenGui:Destroy()
end)
